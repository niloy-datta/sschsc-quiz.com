# Shared env — copy to .env (project root) or backend/.env
# Backend loads backend/.env first, then this file (see backend/app/config.py)
ENVIRONMENT=development
JWT_SECRET=change-this-secret
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Firebase (server + token verification)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# Optional: JSON string for Firebase Admin on Vercel/Lambda
# FIREBASE_SERVICE_ACCOUNT=

ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@example.com

# Legacy / unused by FastAPI (Prisma package only — not active in app)
# DATABASE_URL=
