# FastAPI backend — copy to backend/.env or use project root .env

ENVIRONMENT=development
JWT_SECRET=change-this-secret
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Firebase (server + Firestore REST)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# Optional: JSON string for Firebase Admin on serverless
# FIREBASE_SERVICE_ACCOUNT=

ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@example.com

# Legacy / unused (Prisma only — active DB is Firestore REST)
# DATABASE_URL=

# --- Vercel production (server env vars, never NEXT_PUBLIC_) ---
# ENVIRONMENT=production
# FRONTEND_URL=https://your-domain.com
# APP_URL=https://your-domain.com
# JWT_SECRET=<strong-random-secret>
# ADMIN_PASSWORD=<strong-admin-password>
# FIREBASE_PROJECT_ID=<your-project-id>
# VERCEL=1 is set automatically on Vercel
