# Next.js frontend — copy to .env.local

# Local dev: proxy /api/* to FastAPI (same-origin cookies + SameSite=Lax)
NEXT_PUBLIC_USE_API_PROXY=true
# Leave empty when proxy is enabled; set http://localhost:8000 only if USE_API_PROXY=false
NEXT_PUBLIC_API_URL=

# Used by sitemap.xml and robots.txt. Set to your production domain on Vercel.
NEXT_PUBLIC_SITE_URL=https://sschsc-quiz.com

# Mirror backend FIREBASE_* values with NEXT_PUBLIC_ prefix (client-safe only)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Vercel production (set in Vercel dashboard, not in .env.local) ---
# NEXT_PUBLIC_USE_API_PROXY=true
# NEXT_PUBLIC_API_URL=   (empty — same-origin /api/* via vercel.json → Python)
# NEXT_PUBLIC_SITE_URL=https://sschsc-quiz.com
# Do NOT set NEXT_PUBLIC_* for JWT_SECRET, ADMIN_PASSWORD, or FIREBASE_SERVICE_ACCOUNT
